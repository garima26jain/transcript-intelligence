# Copy to .env and fill in. Never commit .env.
ANTHROPIC_API_KEY=

# Optional — observability. Leave empty to no-op.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional — override model routing (see ti/config.py for defaults)
TI_MODEL_SCREEN=claude-haiku-4-5
TI_MODEL_CLASSIFY=claude-sonnet-4-6
TI_MODEL_SYNTHESIZE=claude-opus-4-7
